      "publishDate": "2026-07-19",
      "coverUrl": "https://images.unsplash.com/photo-1511671782779-c97d3d27a1d4?w=800&auto=format&fit=crop&q=80",
      "author": "Siti Rahmawati",
      "status": "published",
